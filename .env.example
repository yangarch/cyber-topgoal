# 접근 보호 설정
# 이 파일을 .env 로 복사한 뒤 값을 채우세요:  cp .env.example .env

# 친구들과 공유하는 공용 비밀번호. (비워두면 인증이 꺼지고 누구나 접속 가능)
ACCESS_PASSWORD=change-me

# 쿠키 서명용 비밀 키. 아무 긴 랜덤 문자열이면 됩니다.
#   python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# HTTPS(도메인+SSL)로 서비스할 때만 true. 순수 HTTP(로컬/LAN)면 false 로 두세요.
COOKIE_SECURE=false
